def generate_session_key() -> str:
    return Fernet.generate_key().decode()

def validate_username(name: str) -> bool:
    return bool(re.fullmatch(r"[A-Za-z0-9_.]{1,32}", name))

def validate_password(pw: str) -> bool:
    return 1 <= len(pw) <= 128

def auth_limited(ip: str) -> bool:
    now = time.time()
    bucket = [t for t in auth_failures.get(ip, []) if now - t < AUTH_FAIL_WINDOW_SEC]
    auth_failures[ip] = bucket
    return len(bucket) >= AUTH_FAIL_LIMIT

def register_auth_failure(ip: str) -> None:
    now = time.time()
    bucket = [t for t in auth_failures.get(ip, []) if now - t < AUTH_FAIL_WINDOW_SEC]
    bucket.append(now)
    auth_failures[ip] = bucket

def clear_auth_failures(ip: str) -> None:
    auth_failures.pop(ip, None)

def totp_limited(username: str) -> bool:
    now = time.time()
    row = db.execute("SELECT totp_failures, totp_last_fail FROM users WHERE username=?", (username,)).fetchone()
    if not row:
        return False
    failures, last_fail = row
    if failures >= TOTP_FAIL_LIMIT and now - (last_fail or 0) < TOTP_FAIL_WINDOW_SEC:
        return True
    return False

def register_totp_failure(username: str) -> None:
    now = time.time()
    db.execute("UPDATE users SET totp_failures = totp_failures + 1, totp_last_fail = ? WHERE username=?", (now, username))
    db.commit()

def clear_totp_failures(username: str) -> None:
    db.execute("UPDATE users SET totp_failures = 0, totp_last_fail = NULL WHERE username=?", (username,))
    db.commit()

def hash_password(password: str, salt: bytes = None) -> Tuple[str, str]:
    if salt is None:
        salt = os.urandom(32)
    kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=200000)
    key = base64.urlsafe_b64encode(kdf.derive(password.encode()))
    return base64.b64encode(key).decode(), base64.b64encode(salt).decode()

def verify_password(password: str, stored_hash: str, salt_b64: str) -> bool:
    try:
        salt = base64.b64decode(salt_b64)
        computed, _ = hash_password(password, salt)
        return hmac.compare_digest(computed, stored_hash)
    except:
        return False

def totp_code(secret_b32: str, t: int = None) -> str:
    if t is None:
        t = int(time.time()) // 30
    try:
        key = base64.b32decode(str(secret_b32).upper() + "=" * (-len(str(secret_b32)) % 8))
    except Exception:
        return "000000"
    msg = struct.pack(">Q", t)
    h = hmac.new(key, msg, hashlib.sha1).digest()
    offset = h[-1] & 0x0F
    code = struct.unpack(">I", h[offset:offset + 4])[0] & 0x7FFFFFFF
    return str(code % 1000000).zfill(6)

def verify_totp(secret_b32: str, user_code: str, window: int = 1) -> bool:
    user_code = str(user_code or "").strip()
    if len(user_code) != 6 or not user_code.isdigit():
        return False
    base_t = int(time.time()) // 30
    for d in range(-window, window + 1):
        if hmac.compare_digest(totp_code(secret_b32, base_t + d), user_code):
            return True
    return False

def is_message_expired(ts: float, ttl: int, now: Optional[float] = None) -> bool:
    ttl = int(ttl or 0)
    if ttl <= 0:
        return False
    now_v = float(now if now is not None else time.time())
    return (float(ts or 0.0) + ttl) <= now_v

def room_label(room_id: int) -> str:
    return f"__room__:{room_id}"

def is_room_member(room_id: int, username: str) -> bool:
    if room_id in room_members_cache:
        return username in room_members_cache[room_id]
    row = db.execute("SELECT 1 FROM room_members WHERE room_id=? AND username=?", (room_id, username)).fetchone()
    return row is not None

def get_room_members(room_id: int) -> Set[str]:
    if room_id in room_members_cache:
        return room_members_cache[room_id]
    rows = db.execute("SELECT username FROM room_members WHERE room_id=?", (room_id,)).fetchall()
    members = {row[0] for row in rows}
    room_members_cache[room_id] = members
    return members

async def broadcast_to_room(room_id: int, message: dict, exclude: str = None):
    members = get_room_members(room_id)
    for username in list(members):
        if username == exclude:
            continue
        if username in clients:
            writer = clients[username]["writer"]
            cipher = clients[username]["cipher"]
            try:
                enc = cipher.encrypt(json.dumps(message).encode())
                writer.write(enc + SEP.encode())
                await writer.drain()
            except:
                pass

