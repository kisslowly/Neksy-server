def sanitize_sensitive(value: Any) -> str:
    text = str(value or "")
    text = re.sub(r"vless://[^\s]+", "vless://***", text, flags=re.IGNORECASE)
    text = re.sub(r"(?i)(password|passwd|token|secret|key)=([^\s&;]+)", r"\1=***", text)
    text = re.sub(r"(?i)(\"(?:password|token|secret|key)\"\s*:\s*\")[^\"]+", r"\1***", text)
    text = re.sub(r"(?i)(://[^:/\s]+:)[^@/\s]+@", r"\1***@", text)
    return text

def dbg(*args):
    if DEBUG and not NO_LOGS_MODE:
        print("[SERVER DBG]", *(sanitize_sensitive(a) for a in args))

def event_type_for_packet(mtype: str) -> str:
    mapping = {
        "chat": "text", "msg_reply": "text", "media_meta": "file", "media_chunk": "file",
        "msg_react": "reaction", "typing": "status", "msg_status": "status", "ping": "status",
        "pong": "status", "users": "status", "room_list": "system", "wall_list": "system",
    }
    return mapping.get(str(mtype or ""), "system")

class ServerCryptoLayer:
    def __init__(self, session_key: str):
        self.session_key = str(session_key or "")
        self._fernet = Fernet(self.session_key.encode())
        self._seen_nonces: Dict[str, float] = {}
        self.encrypted_count = 0
        self.decrypted_count = 0

    def encrypt(self, payload: bytes) -> bytes:
        data = payload
        try:
            msg = json.loads(payload.decode("utf-8"))
            if isinstance(msg, dict):
                msg.setdefault("protocol_version", SECURITY_PROTOCOL_VERSION)
                msg.setdefault("event_type", event_type_for_packet(msg.get("type", "")))
                msg.setdefault("nonce", secrets.token_urlsafe(18))
                msg.setdefault("timestamp", time.time())
                data = json.dumps(msg, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
        except Exception:
            pass
        self.encrypted_count += 1
        return self._fernet.encrypt(data)

    def decrypt(self, token: bytes) -> bytes:
        if len(token) > MAX_MESSAGE_SIZE:
            raise ValueError("encrypted token too large")
        data = self._fernet.decrypt(token)
        try:
            msg = json.loads(data.decode("utf-8"))
            if isinstance(msg, dict):
                self._validate_protocol(msg)
                self._validate_timestamp(msg)
                self._validate_nonce(msg)
                data = json.dumps(msg, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
        except ValueError:
            raise
        except Exception:
            pass
        self.decrypted_count += 1
        return data

    def _validate_protocol(self, msg: Dict[str, Any]) -> None:
        version = msg.get("protocol_version")
        if version is None:
            return
        try:
            if int(version) < SECURITY_PROTOCOL_VERSION:
                raise ValueError("protocol downgrade rejected")
        except ValueError:
            raise

    def _validate_timestamp(self, msg: Dict[str, Any]) -> None:
        if "timestamp" not in msg:
            return
        try:
            ts = float(msg.get("timestamp") or 0)
        except Exception as exc:
            raise ValueError("invalid timestamp") from exc
        if abs(time.time() - ts) > SECURITY_TIMESTAMP_WINDOW_SEC:
            raise ValueError("timestamp outside accepted window")

    def _validate_nonce(self, msg: Dict[str, Any]) -> None:
        nonce = str(msg.get("nonce", "") or "")
        if not nonce:
            return
        now = time.time()
        expired = [n for n, ts in self._seen_nonces.items() if now - ts > SECURITY_TIMESTAMP_WINDOW_SEC]
        for n in expired:
            self._seen_nonces.pop(n, None)
        if nonce in self._seen_nonces:
            raise ValueError("replay nonce rejected")
        self._seen_nonces[nonce] = now
        if len(self._seen_nonces) > SECURITY_REPLAY_CACHE_LIMIT:
            for n, _ts in sorted(self._seen_nonces.items(), key=lambda item: item[1])[:512]:
                self._seen_nonces.pop(n, None)

    def wipe(self) -> None:
        self._seen_nonces.clear()
        self.session_key = ""
        self._fernet = None

