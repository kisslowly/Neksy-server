                username TEXT,
                session_id TEXT,
                chunk_count INTEGER DEFAULT 0,
                last_update REAL,
                PRIMARY KEY (username, session_id)
            );
        """)
        self.conn.commit()

    def _migrate(self):
        """Safe migration without direct string interpolation."""
        existing_cols = {}
        for table in ["users", "messages", "wall_threads", "wall_comments", "rooms"]:
            existing_cols[table] = {row[1] for row in self.conn.execute(f"PRAGMA table_info({table})").fetchall()}

        # users
        if "totp_failures" not in existing_cols["users"]:
            self.conn.execute("ALTER TABLE users ADD COLUMN totp_failures INTEGER DEFAULT 0")
        if "totp_last_fail" not in existing_cols["users"]:
            self.conn.execute("ALTER TABLE users ADD COLUMN totp_last_fail REAL")
        if "last_login" not in existing_cols["users"]:
            self.conn.execute("ALTER TABLE users ADD COLUMN last_login REAL")
        if "login_count" not in existing_cols["users"]:
            self.conn.execute("ALTER TABLE users ADD COLUMN login_count INTEGER DEFAULT 0")
        if "ip_address" not in existing_cols["users"]:
            self.conn.execute("ALTER TABLE users ADD COLUMN ip_address TEXT")

        # messages
        if "edited_at" not in existing_cols["messages"]:
            self.conn.execute("ALTER TABLE messages ADD COLUMN edited_at REAL")
        if "edit_count" not in existing_cols["messages"]:
            self.conn.execute("ALTER TABLE messages ADD COLUMN edit_count INTEGER DEFAULT 0")
        if "ttl" not in existing_cols["messages"]:
            self.conn.execute("ALTER TABLE messages ADD COLUMN ttl INTEGER DEFAULT 0")

        # wall_threads
        if "view_count" not in existing_cols["wall_threads"]:
            self.conn.execute("ALTER TABLE wall_threads ADD COLUMN view_count INTEGER DEFAULT 0")

        # wall_comments
        if "edited_at" not in existing_cols["wall_comments"]:
            self.conn.execute("ALTER TABLE wall_comments ADD COLUMN edited_at REAL")

        # rooms
        if "description" not in existing_cols["rooms"]:
            self.conn.execute("ALTER TABLE rooms ADD COLUMN description TEXT DEFAULT ''")
        if "icon" not in existing_cols["rooms"]:
            self.conn.execute("ALTER TABLE rooms ADD COLUMN icon TEXT")

        self.conn.commit()

    def execute(self, sql: str, params=()):
        return self.conn.execute(sql, params)

    def commit(self):
        self.conn.commit()

