    def __init__(self):
        self.conn = sqlite3.connect(DB_FILE, check_same_thread=False)
        self._init_tables()
        self._migrate()

    def _init_tables(self):
        self.conn.executescript("""
            CREATE TABLE IF NOT EXISTS users (
                username TEXT PRIMARY KEY,
                password_hash TEXT,
                salt TEXT,
                public_key TEXT,
                avatar_color TEXT DEFAULT '#6c8efb',
                avatar_image TEXT,
